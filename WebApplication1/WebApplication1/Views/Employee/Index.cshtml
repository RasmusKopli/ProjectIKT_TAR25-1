@model IEnumerable<Projekt.Models.Employee>

@{
	ViewData["Title"] = "Employees";
}

<h1>Employees</h1>

<a asp-action="Create" class="btn btn-primary mb-3">Create New Employee</a>

<table class="table">
	<thead>
		<tr>
			<th>Name</th>
			<th>Position</th>
			<th>Reputation</th>
			<th>Wage</th>
		</tr>
	</thead>
	<tbody>
		@foreach (var employee in Model)
		{
			<tr>
				<td>@employee.Name</td>
				<td>@(employee.JobPosition != null ? employee.JobPosition.JobName : employee.Position)</td>
				<td>@employee.Reputation</td>
				<td>@employee.Wage</td>
				<td>
					<a asp-action="Details" asp-route-id="@employee.Id">Details</a>
					<a asp-action="Edit" asp-route-id="@employee.Id" class="btn btn-sm btn-warning">Edit</a>
					<a asp-action="Delete" asp-route-id="@employee.Id" class="btn btn-sm btn-danger">Delete</a>
				</td>
			</tr>
		}
	</tbody>
</table>
