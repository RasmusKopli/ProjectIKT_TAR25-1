@model Projekt.Models.Employee

@{
	ViewData["Title"] = "Delete Employee";
}

<p>Are you sure you want to delete this employee?</p>

<d1 class="row">
	<dt class="col-sm-2">Name</dt>
	<dd class="col-sm-10">@Model.Name</dd>

	<dt class="col-sm-2">Position</dt>
	<dd class="col-sm-10">@(Model.JobPosition != null ? Model.JobPosition.JobName : Model.Position)</dd>

	<dt class="col-sm-2">Reputation</dt>
	<dd class="col-sm-10">@Model.Reputation</dd>

	<dt class="col-sm-2">Wage</dt>
	<dd class="col-sm-10">@Model.Wage</dd>
</d1>

<form asp-action="Delete">
	<input type="hidden" asp-for="Id" />
	<button type="submit" class="btn btn-danger">Delete</button>
	<a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>