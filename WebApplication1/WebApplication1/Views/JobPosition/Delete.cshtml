@model Projekt.ViewModels.JobPositionVM.JobPositionDeleteViewModel

@{
	ViewData["Title"] = "Delete Job Position";
}

<h1>Delete Job Position</h1>

<p>Are you sure you want to delete this job position?</p>

<d1 class="row">
	<dt class="col-sm-2">Job Name</dt>
	<dd class="col-sm-10">@Model.JobName</dd>

	<dt class="col-sm-2">Job ID</dt>
	<dd class="col-sm-10">@Model.JobId</dd>

	<dt class="col-sm-2">Salary</dt>
	<dd class="col-sm-10">@Model.Salary</dd>

	<dt class="col-sm-12">Available</dt>
	<dd class="col-sm-10">@Model.IsAvailable</dd>
</d1>

<form asp-action="Delete" method="post">
	@Html.AntiForgeryToken()
	<input type="hidden" asp-for="Id" />
	<button type="submit" class="btn btn-danger">Delete</button>
	<a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
