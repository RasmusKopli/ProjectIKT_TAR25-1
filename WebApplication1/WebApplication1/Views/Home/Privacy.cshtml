@{
    ViewData["Title"] = "Privacy Policy";
}

<div style="max-width:800px; margin:40px auto; padding:0 20px;">
    <h1>Privacy Policy</h1>
    <p style="color:gray;">Last updated: June 2026</p>

    <p>
        Cynosure is an internal employee management system.
        This page outlines how we handle data within the application.
    </p>

    <h3>Data Collection</h3>
    <p>
        Cynosure collects and stores employee information including name, position,
        reputation, and wage. This data is used solely for internal management purposes.
    </p>

    <h3>Data Usage</h3>
    <p>
        All data stored in Cynosure is strictly for internal use and is not shared
        with any third parties.
    </p>

    <h3>Data Security</h3>
    <p>
        Access to employee data is restricted to authorized users only.
        We take reasonable measures to protect all stored information.
    </p>

    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary" style="margin-top:20px;">
        Back to Home
    </a>
</div>
